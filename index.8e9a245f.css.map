    width: 100%;
    overflow-y: hidden;
    visibility: visible;
  }
}
.sidebar-slide {
  animation: slide-sidebar 0.4s;
  visibility: visible;
}
@keyframes slide-sidebar {
  0% {
    margin-left: -25%;
  }
  100% {
    margin-left: 0%;
  }
}
.sidebar-hide {
  animation: hide-sidebar 0.4s;
  visibility: visible;
  margin-left: -50%;
}
@keyframes hide-sidebar {
  0% {
    margin-left: 0%;
  }
  100% {
    margin-left: -25%;
  }
}
