.filler {
  width: 75%;
  visibility: hidden;
  background-color: #b8b8c5;
  height: 100%;
  left: 50%;
  z-index: 2;
  opacity: 0.7;
}
@media (min-width: 851px) {
  .filler {
    visibility: hidden;
  }
}
.filler-slide {
  animation: slide-filler 0.4s;
  visibility: visible;
}
@keyframes slide-filler {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 0.7;
  }
}
.filler-hide {
  animation: hide-filler 0.4s;
}
@keyframes hide-filler {
  0% {
    opacity: 0.7;
  }
  99% {
    visibility: visible;
  }
  100% {
    opacity: 0;
    visibility: hidden;
  }
}
