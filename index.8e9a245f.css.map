.theme-switch {
  position: relative;
  display: inline-block;
  width: 46px;
  height: 22px;
  transform: rotate(90deg);
  margin-left: 8px;
}
@media (min-width: 521px) {
  .theme-switch {
    margin-left: 15px;
    width: 48px;
    height: 24px;
    transform: rotate(0deg);
  }
}
@media (min-width: 851px) {
  .theme-switch {
    margin-left: -38px;
    width: 50px;
    height: 26px;
    margin-right: 48px;
  }
}
@media (min-width: 1401px) {
  .theme-switch {
    width: 52px;
    height: 28px;
  }
}
@media (min-width: 1921px) {
  .theme-switch {
    margin-right: 43px;
  }
}
.theme-switch input {
  opacity: 0;
  width: 0;
  height: 0;
}
.theme-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #d3edee;
  transition: 0.4s;
}
.theme-slider:before {
  position: absolute;
  content: "";
  height: 32px;
  width: 32px;
  left: 0px;
  bottom: 4px;
  top: 0;
  bottom: 0;
  margin: auto 0;
  transition: 0.4s;
  box-shadow: rgba(0, 0, 0, 0.15) 1.95px 1.95px 2.6px;
  background: #112b2c url("https://i.ibb.co/FxzBYR9/night.png");
  background-repeat: no-repeat;
  background-position: center;
  transform: rotate(270deg);
}
@media (min-width: 521px) {
  .theme-slider:before {
    transform: rotate(0deg);
  }
}
@media (min-width: 851px) {
  .theme-slider:before {
    height: 34px;
    width: 34px;
  }
}
@media (min-width: 1401px) {
  .theme-slider:before {
    height: 36px;
    width: 36px;
  }
}
input:checked + .theme-slider {
  background-color: #276568;
}
input:focus + .theme-slider {
  box-shadow: 0 0 1px #276568;
}
input:checked + .theme-slider:before {
  transform: translateX(14px) rotate(90deg);
  background: #f0f9f9 url("https://i.ibb.co/7JfqXxB/sunny.png");
  background-repeat: no-repeat;
  background-position: center;
}
@media (min-width: 521px) {
  input:checked + .theme-slider:before {
    transform: translateX(16px) rotate(0deg);
  }
}
@media (min-width: 851px) {
  input:checked + .theme-slider:before {
    transform: translateX(18px);
  }
}
@media (min-width: 1401px) {
  input:checked + .theme-slider:before {
    transform: translateX(20px);
  }
}
.theme-slider.round {
  border-radius: 26px;
}
.theme-slider.round:before {
  border-radius: 50%;
}
