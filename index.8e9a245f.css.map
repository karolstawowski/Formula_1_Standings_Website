/*
    Color palette:
    #59BDC0 - Maximum Blue Green
    #19838A - Metallic Seaweed
    #A31621 - Ruby Red
    #F2F2F2 - Cultured
*/
.navbar {
  color: white;
  width: 100%;
  height: 124px;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  position: fixed;
  top: 0;
  left: 0;
  min-width: 350px;
}
.navbar-slide {
  animation: slide-navbar 0.4s;
  visibility: visible;
  margin-left: 50%;
}
@keyframes slide-navbar {
  0% {
    margin-left: 0%;
  }
  100% {
    margin-left: 50%;
  }
}
.navbar-hide {
  animation: hide-navbar 0.4s;
}
@keyframes hide-navbar {
  0% {
    margin-left: 50%;
  }
  100% {
    margin-left: 0%;
  }
}
.navbar-logo-section {
  width: 100%;
  height: 64px;
  background-color: #59bdc0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
}
@media (min-width: 1921px) {
  .navbar-logo-section {
    height: 70px;
  }
}
.sidebar-and-theme-switches {
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}
.menu-bar-icon {
  height: 38px;
  width: 42px;
  margin-left: 13px;
  cursor: pointer;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-content: space-evenly;
  background-color: #19868a;
  box-shadow: rgba(0, 0, 0, 0.15) 1.95px 1.95px 2.6px;
}
@media (min-width: 851px) {
