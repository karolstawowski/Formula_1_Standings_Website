    visibility: hidden;
  }
}
.menu-bar-icon > div {
  height: 4px;
  width: 32px;
  background-color: #f2f2f2;
}
.logo {
  display: block;
  padding: 7px 0px;
  height: 50px;
  width: 117px;
  position: relative;
  display: block;
  top: auto;
  left: auto;
}
@media (min-width: 521px) {
  .logo {
    padding: 4px 0px;
    height: 54px;
    width: 126px;
  }
}
.language-buttons {
  display: flex;
